<?xml version="1.0" encoding="utf-8"?>
<!--
  DSLR/미러리스 제조사 VID + PTP 클래스만 허용.
  비-카메라 VID(스마트폰/HID/스토리지 등)는 모두 제거하여
  Apple/Samsung/Google 폰을 USB OTG로 연결했을 때 본 앱이
  잘못 진입하는 문제를 방지한다.
  실제 libgphoto2 초기화 시점에는 UsbConnectionManager.ALLOWED_CAMERA_VENDOR_IDS
  가 한 번 더 검증한다.
-->
<resources>
    <!-- 주요 DSLR/미러리스 제조사 -->
    <usb-device vendor-id="1193" />  <!-- Canon       0x04A9 -->
    <usb-device vendor-id="1200" />  <!-- Nikon       0x04B0 -->
    <usb-device vendor-id="1356" />  <!-- Sony        0x054C -->
    <usb-device vendor-id="1227" />  <!-- Fujifilm    0x04CB -->
    <usb-device vendor-id="1242" />  <!-- Panasonic   0x04DA -->
    <usb-device vendor-id="1972" />  <!-- Olympus     0x07B4 -->
    <usb-device vendor-id="9723" />  <!-- Pentax/Ricoh 0x25FB -->
    <usb-device vendor-id="6808" />  <!-- Leica Camera AG 0x1A98 (구 6211=0x1843 Vaisala 오기 교정) -->
    <usb-device vendor-id="7899" />  <!-- Blackmagic  0x1EDB -->

    <!-- 일반적인 PTP 카메라 클래스 (벤더 미상 카메라용) -->
    <usb-device
        class="6"
        subclass="1"
        protocol="1" />   <!-- 정지 영상 캡처 장치 -->
</resources>
