<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 자체 앱만 커스텀 브로드캐스트를 전송할 수 있도록 signature-level permission 선언 -->
    <permission
        android:name="com.inik.camcon.permission.WIFI_AUTO_CONNECT"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.inik.camcon.permission.WIFI_AUTO_CONNECT" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Wi-Fi 권한 추가 (PTPIP용) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <!-- mDNS Multicast 패킷 수신 (PTP/IP 카메라 검색) -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Android 13+ 근처 Wi‑Fi 스캔/연결 권한 -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        tools:targetApi="33" />
    <!-- Android 13+ 알림 권한 -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 사진 도착 시 진동 알림 (normal 권한) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- 재부팅 시 자동 시작 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 파일 시스템 접근 권한 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Android 13+ 세분화된 미디어 권한 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" /> -->

    <!-- Google Play Services 관련 권한 추가 -->
    <uses-permission android:name="com.google.android.providers.gsf.permission.READ_GSERVICES" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />

    <!-- USB Host 모드 지원 선언 -->
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="true" />

    <!-- Wi-Fi 기능 지원 선언 (PTPIP용) -->
    <uses-feature
        android:name="android.hardware.wifi"
        android:required="false" />

    <application
        android:name=".CamCon"
        android:largeHeap="true"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CamCon"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- Google Play Services 버전 메타데이터 추가 -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- Firebase 및 Google Services 설정 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_launcher_monochrome" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/colorPrimary" />

        <activity
            android:name=".presentation.ui.SplashActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- USB 디바이스 연결 시 앱 실행 -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>
        <activity
            android:name=".presentation.ui.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".presentation.ui.MainActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="fullSensor"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|locale|layoutDirection|uiMode|density|fontScale|smallestScreenSize" />
        <activity
            android:name=".presentation.ui.SettingsActivity"
            android:exported="false"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".presentation.ui.SubscriptionActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:theme="@style/Theme.CamCon"
            android:label="@string/subscription_title" />
        <activity
            android:name=".presentation.ui.PtpipConnectionActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:label="@string/wifi_camera_connection" />
        <activity
            android:name=".presentation.ui.ColorTransferSettingsActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:label="@string/color_transfer_settings" />
        <activity
            android:name=".presentation.ui.FilmEditorActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:label="@string/film_simulation_settings" />
        <activity
            android:name=".presentation.ui.OpenSourceLicensesActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:label="@string/open_source_licenses" />
        <activity
            android:name=".presentation.ui.CameraAbilitiesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CamCon"
            android:label="@string/diag_abilities_title" />

        <!-- FileProvider for sharing photos -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Wi-Fi 자동 연결 콜백 수신 -->
        <receiver
            android:name=".data.receiver.WifiSuggestionBroadcastReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="com.inik.camcon.permission.WIFI_AUTO_CONNECT">
            <intent-filter>
                <!-- WiFi Suggestion 연결 후 (시스템 브로드캐스트) -->
                <action android:name="android.net.wifi.action.WIFI_NETWORK_SUGGESTION_POST_CONNECTION" />
                <!-- 커스텀 브로드캐스트 -->
                <action android:name="com.inik.camcon.action.AUTO_CONNECT_TRIGGER" />
                <action android:name="com.inik.camcon.action.AUTO_CONNECT_SUCCESS" />
                <!-- WiFi 상태 변화 (Android 10+ 에서도 작동) -->
                <action android:name="android.net.wifi.STATE_CHANGE" />
                <action android:name="android.net.wifi.supplicant.CONNECTION_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- 재부팅 시 자동 시작 -->
        <!-- android:permission 으로 시스템(BOOT_COMPLETED 권한 보유)에서만 호출 가능하도록 제한 -->
        <receiver
            android:name=".data.receiver.BootCompletedReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 자동 연결용 Foreground Service -->
        <service
            android:name=".data.service.AutoConnectForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- WiFi 모니터링 Foreground Service (자동 연결 토글 ON 시 상시 실행) -->
        <service
            android:name=".data.service.WifiMonitoringService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice"
            android:stopWithTask="false" />

        <!-- 백그라운드 동기화 서비스 -->
        <service
            android:name=".data.service.BackgroundSyncService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice"
            android:stopWithTask="false" />

    </application>

</manifest>
