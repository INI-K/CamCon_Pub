sealed class BottomNavItem(val route: String, val titleRes: Int, val icon: ImageVector) {
    object PhotoPreview :
        BottomNavItem("photo_preview", R.string.photo_preview, Icons.Default.Photo)

    object CameraControl :
        BottomNavItem("camera_control", R.string.camera_control, Icons.Default.CameraAlt)

    object ServerPhotos :
        BottomNavItem("server_photos", R.string.server_photos, Icons.Default.CloudDownload)

    object Settings :
        BottomNavItem("settings", R.string.settings, Icons.Default.Settings)
}

@Composable
fun CameraConnectionOptimizationDialog(
    onDismissRequest: () -> Unit,
    onGoToSettings: () -> Unit
) {
    AlertDialog(
        onDismissRequest = onDismissRequest,
        icon = { androidx.compose.material3.Icon(Icons.Default.Settings, contentDescription = null) },
        title = {
            androidx.compose.material3.Text(
                "м№ҙл©”лқј м—°кІ° мөңм Ғнҷ” м„Өм •",
                style = androidx.compose.material3.MaterialTheme.typography.titleLarge,
                fontWeight = FontWeight.Bold
            )
        },
        text = {
            Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
                androidx.compose.material3.Text(
                    text = "м№ҙл©”лқјмҷҖмқҳ м•Ҳм •м Ғмқё м—°кІ°мқ„ мң„н•ҙ л°°н„°лҰ¬ мөңм Ғнҷ” мҳҲмҷё м„Өм •мқ„ к¶ҢмһҘн•©лӢҲлӢӨ.",
                    style = androidx.compose.material3.MaterialTheme.typography.bodyLarge
                )
                androidx.compose.material3.Text(
                    text = "вҖў мӢӨмӢңк°„ м№ҙл©”лқј м ңм–ҙ мң м§Җ\n" +
                            "вҖў мӮ¬м§„ мһҗлҸҷ м „мҶЎ м•Ҳм •м„ұ н–ҘмғҒ\n" +
                            "вҖў л°ұк·ёлқјмҡҙл“ң м—°кІ° лҒҠк№Җ л°©м§Җ\n\n" +
                            "вҖ» м№ҙл©”лқј мЈјліҖкё°кё° м—°кІ° м•ұмңјлЎңм„ң Google Play м •мұ…м—җ л”°лқј н—Ҳмҡ©лҗ©лӢҲлӢӨ.",
                    style = androidx.compose.material3.MaterialTheme.typography.bodyMedium,
                    color = androidx.compose.material3.MaterialTheme.colorScheme.onSurface.copy(alpha = 0.8f)
                )
            }
        },
        confirmButton = {
            androidx.compose.material3.Button(onClick = onGoToSettings) {
                androidx.compose.material3.Text("м„Өм •н•ҳкё°")
            }
        },
        dismissButton = {
            androidx.compose.material3.TextButton(onClick = onDismissRequest) {
                androidx.compose.material3.Text("лӮҳмӨ‘м—җ")
            }
        }
    )
}

@Composable
fun MainScreen(
    onSettingsClick: () -> Unit,
    globalManager: CameraConnectionGlobalManager,
    cameraViewModel: CameraViewModel = hiltViewModel()
) {
    val navController = rememberNavController()
    val items = listOf(
        BottomNavItem.PhotoPreview,
        BottomNavItem.CameraControl,
        BottomNavItem.ServerPhotos,
        BottomNavItem.Settings
    )

    // м „мІҙнҷ”л©ҙ мғҒнғң кҙҖлҰ¬
    var isFullscreen by remember { mutableStateOf(false) }

    // PTPIP м—°кІ° мғҒнғң л°Ҹ кІҪкі  лӢӨмқҙм–јлЎңк·ё мғҒнғң
    val isPtpipConnected by cameraViewModel.isPtpipConnected.collectAsState()
    var showPtpipWarning by remember { mutableStateOf(false) }

    // м „м—ӯ м—°кІ° мғҒнғң лӘЁлӢҲн„°л§Ғ
    val globalConnectionState by globalManager.globalConnectionState.collectAsState()
    val activeConnectionType by globalManager.activeConnectionType.collectAsState()
    val connectionStatusMessage by globalManager.connectionStatusMessage.collectAsState()

    // CameraViewModelмқҳ USB мҙҲкё°нҷ” мғҒнғң лӘЁлӢҲн„°л§Ғ
    val cameraUiState by cameraViewModel.uiState.collectAsState()

    // LocalContextлҘј @Composable лӮҙм—җм„ң лҜёлҰ¬ к°Җм ёмҳӨкё°
    val context = LocalContext.current

    // м „м—ӯ мғҒнғң ліҖнҷ” мӢң лЎңк·ё м¶ңл Ҙ
    LaunchedEffect(globalConnectionState) {
        LogcatManager.d("MainScreen", "м „м—ӯ м—°кІ° мғҒнғң ліҖнҷ”: $connectionStatusMessage")
    }

    // н…Ңл§Ҳ лӘЁл“ң мғҒнғң
    val appSettingsViewModel: AppSettingsViewModel = hiltViewModel()
    val themeMode by appSettingsViewModel.themeMode.collectAsState()

    Box(
        modifier = Modifier.fillMaxSize()
    ) {

        // --- PTP нғҖмһ„м•„мӣғ лӢӨмқҙм–јлЎңк·ё лӘЁлӢҲн„°л§Ғ л°Ҹ н‘ңмӢң ---
        var showRestartDialog by remember { mutableStateOf(false) }

        if (cameraUiState.isPtpTimeout == true && !showRestartDialog) {
            PtpTimeoutDialog(
                onDismissRequest = { cameraViewModel.clearPtpTimeout() },
                onRestartRequest = {
                    showRestartDialog = true
                }
            )
        }

        // м•ұ мһ¬мӢңмһ‘ лӢӨмқҙм–јлЎңк·ё н‘ңмӢң
        if (showRestartDialog) {
            var isRestarting by remember { mutableStateOf(false) }

            androidx.compose.material.AlertDialog(
                onDismissRequest = { /* лӢӨмқҙм–јлЎңк·ё лӢ«кё° л°©м§Җ */ },
                title = { Text("м•ұ мһ¬мӢңмһ‘ н•„мҡ”") },
                text = {
                androidx.compose.foundation.layout.Column {
                    if (isRestarting) {
                        Text("мһ¬мӢңмһ‘ мӨҖл№„ мӨ‘мһ…лӢҲлӢӨ...")
                        androidx.compose.foundation.layout.Spacer(
                            modifier = androidx.compose.ui.Modifier.height(8.dp)
                        )
                        Text(
                            "мһ мӢңл§Ң кё°лӢӨл ӨмЈјм„ёмҡ”. м№ҙл©”лқј м—°кІ°мқ„ м •лҰ¬н•ҳкі  мһҲмҠөлӢҲлӢӨ.",
                            style = androidx.compose.material.MaterialTheme.typography.caption
                        )
                    } else {
                        Text("м№ҙл©”лқј м—°кІ° л¬ём ңлЎң мқён•ҙ м•ұмқ„ мҷ„м „нһҲ мһ¬мӢңмһ‘н•ҙм•ј н•©лӢҲлӢӨ.")
                        androidx.compose.foundation.layout.Spacer(
                            modifier = androidx.compose.ui.Modifier.height(8.dp)
                        )
                        Text(
                            "вҖў 'мҰүмӢң мһ¬мӢңмһ‘': лІ„нҠј нҒҙлҰӯ мҰүмӢң мһ¬мӢңмһ‘\nвҖў 'мў…лЈҢ': м•ұл§Ң мў…лЈҢ (мҲҳлҸҷ мһ¬мӢӨн–ү н•„мҡ”)",
                            style = androidx.compose.material.MaterialTheme.typography.caption
                        )
                    }
                    }
                },
                confirmButton = {
                    if (!isRestarting) {
                        androidx.compose.foundation.layout.Row(
                            horizontalArrangement = androidx.compose.foundation.layout.Arrangement.spacedBy(
                                8.dp
                            )
                        ) {
                            androidx.compose.material.TextButton(
                                onClick = {
                                    isRestarting = true
                                    // лӘЁл“  мғҒнғң м •лҰ¬
                                    cameraViewModel.clearPtpTimeout()

                                    // мӢңмҠӨн…ң мһ¬мӢңмһ‘ л©”м»ӨлӢҲмҰҳмқ„ мӮ¬мҡ©н•ң мһ¬мӢңмһ‘
                                    val activity = context as? ComponentActivity
                                    activity?.let { act ->
                                        MainActivity.restartAppAfterCameraCleanup(act)
                                    }
                                }
                            ) { Text("мҰүмӢң мһ¬мӢңмһ‘") }

                            androidx.compose.material.TextButton(
                                onClick = {
                                    isRestarting = true
                                    // лӘЁл“  мғҒнғң м •лҰ¬
                                    cameraViewModel.clearPtpTimeout()

                                    // к°„лӢЁн•ң мһ¬мӢңмһ‘ (м•ұ мў…лЈҢл§Ң)
                                    val activity = context as? ComponentActivity
                                    activity?.let { act ->
                                        MainActivity.systemRestartApp(act)
                                    }
                                }
                            ) { Text("мў…лЈҢ") }
                        }
                    }
                },
                properties = androidx.compose.ui.window.DialogProperties(
                    dismissOnBackPress = false,
                    dismissOnClickOutside = false
                )
            )
        }

        // USB л¶„лҰ¬ лӢӨмқҙм–јлЎңк·ё н‘ңмӢң
        if (cameraUiState.isUsbDisconnected == true) {
            androidx.compose.material.AlertDialog(
                onDismissRequest = { cameraViewModel.clearUsbDisconnection() },
                title = {
                    Text(
                        "USB л””л°”мқҙмҠӨ л¶„лҰ¬",
                        style = MaterialTheme.typography.h6,
                        fontWeight = androidx.compose.ui.text.font.FontWeight.Bold,
                        color = MaterialTheme.colors.error
                    )
                },
                text = {
                    androidx.compose.foundation.layout.Column {
                        Text(
                            "м№ҙл©”лқј USB м—°кІ°мқҙ лҒҠм–ҙмЎҢмҠөлӢҲлӢӨ.",
                            style = MaterialTheme.typography.body1
                        )
                        androidx.compose.foundation.layout.Spacer(
                            modifier = androidx.compose.ui.Modifier.height(
                                8.dp
                            )
                        )
                        Text(
                            "вҖў USB мјҖмқҙлё” м—°кІ°мқ„ нҷ•мқён•ҙмЈјм„ёмҡ”\nвҖў м№ҙл©”лқј м „мӣҗмқ„ нҷ•мқён•ҙмЈјм„ёмҡ”\nвҖў м№ҙл©”лқјлҘј PC лӘЁл“ңлЎң м„Өм •н•ҙмЈјм„ёмҡ”",
                            style = MaterialTheme.typography.caption,
                            color = MaterialTheme.colors.onSurface.copy(
                                alpha = 0.7f
                            )
                        )
                    }
                },
                confirmButton = {
                    androidx.compose.material.TextButton(
                        onClick = { cameraViewModel.clearUsbDisconnection() }
                    ) {
                        Text("нҷ•мқё")
                    }
                },
                properties = androidx.compose.ui.window.DialogProperties(
                    dismissOnBackPress = true,
                    dismissOnClickOutside = true
                )
            )
        }

        // м№ҙл©”лқј мғҒнғң м җкІҖ лӢӨмқҙм–јлЎңк·ё н‘ңмӢң (мҙҲкё°нҷ”к°Җ мҷ„лЈҢлҗң нӣ„м—җл§Ң н‘ңмӢң)
        if (cameraUiState.showCameraStatusCheckDialog == true &&
            !cameraUiState.isUsbInitializing &&
            !cameraUiState.isCameraInitializing
        ) {
            androidx.compose.material.AlertDialog(
                onDismissRequest = { cameraViewModel.dismissCameraStatusCheckDialog() },
                title = {
                    Text(
                        "м№ҙл©”лқј мғҒнғң м җкІҖ н•„мҡ”",
                        style = MaterialTheme.typography.h6,
                        fontWeight = androidx.compose.ui.text.font.FontWeight.Bold,
                        color = MaterialTheme.colors.error
                    )
                },
                text = {
                    androidx.compose.foundation.layout.Column {
                        Text(
                            "м№ҙл©”лқјк°Җ м •мғҒм ҒмңјлЎң лҸҷмһ‘н•ҳм§Җ м•ҠмҠөлӢҲлӢӨ.",
                            style = MaterialTheme.typography.body1
                        )
                        androidx.compose.foundation.layout.Spacer(
                            modifier = androidx.compose.ui.Modifier.height(12.dp)
                        )
                        Text(
                            "лӢӨмқҢ мӮ¬н•ӯмқ„ нҷ•мқён•ҙмЈјм„ёмҡ”:",
                            style = MaterialTheme.typography.body2,
                            fontWeight = androidx.compose.ui.text.font.FontWeight.Bold
                        )
                        androidx.compose.foundation.layout.Spacer(
                            modifier = androidx.compose.ui.Modifier.height(8.dp)
                        )
                        Text(
                            "вҖў м№ҙл©”лқј м „мӣҗмқҙ мјңм ё мһҲлҠ”м§Җ нҷ•мқё\n" +
                                    "вҖў м№ҙл©”лқј л°°н„°лҰ¬к°Җ м¶©л¶„н•ңм§Җ нҷ•мқё\n" +
                                    "вҖў USB мјҖмқҙлё” м—°кІ° мғҒнғң нҷ•мқё\n" +
                                    "вҖў м№ҙл©”лқјк°Җ PC м—°кІ° лӘЁл“ңлЎң м„Өм •лҗҳм–ҙ мһҲлҠ”м§Җ нҷ•мқё\n" +
                                    "вҖў м№ҙл©”лқјлҘј к»җлӢӨк°Җ лӢӨмӢң мјңліҙм„ёмҡ”",
                            style = MaterialTheme.typography.caption,
                            color = MaterialTheme.colors.onSurface.copy(
                                alpha = 0.8f
                            )
                        )
                    }
                },
                confirmButton = {
                    androidx.compose.material.TextButton(
                        onClick = { cameraViewModel.dismissCameraStatusCheckDialog() }
                    ) {
                        Text("нҷ•мқё")
                    }
                },
                dismissButton = {
                    androidx.compose.material.TextButton(
                        onClick = {
                            cameraViewModel.dismissCameraStatusCheckDialog()
                            cameraViewModel.refreshUsbDevices()
                        }
                    ) {
                        Text("лӢӨмӢң м—°кІ°")
                    }
                },
                properties = androidx.compose.ui.window.DialogProperties(
                    dismissOnBackPress = true,
                    dismissOnClickOutside = false // мӮ¬мҡ©мһҗк°Җ лӘ…мӢңм ҒмңјлЎң нҷ•мқён•ҳлҸ„лЎқ
                )
            )
        }

        Scaffold(
            bottomBar = {
                // м „мІҙнҷ”л©ҙ лӘЁл“ңк°Җ м•„лӢҗ л•Ңл§Ң н•ҳлӢЁ нғӯ н‘ңмӢң
                if (!isFullscreen) {
                    BottomNavigation(
                        modifier = Modifier.navigationBarsPadding(),
                        backgroundColor = MaterialTheme.colors.surface,
                        contentColor = MaterialTheme.colors.onSurface
                    ) {
                        val navBackStackEntry by navController.currentBackStackEntryAsState()
                        val currentDestination = navBackStackEntry?.destination

                        items.forEach { screen ->
                            BottomNavigationItem(
                                icon = {
                                    Icon(
                                        screen.icon,
                                        contentDescription = stringResource(screen.titleRes)
                                    )
                                },
                                label = {
                                    Text(stringResource(screen.titleRes))
                                },
                                selected = currentDestination?.hierarchy?.any { it.route == screen.route } == true,
                                onClick = {
                                    if (screen == BottomNavItem.PhotoPreview && isPtpipConnected) {
                                        // PTPIP м—°кІ° мӢң лҜёлҰ¬ліҙкё° нғӯ нҒҙлҰӯн•ҳл©ҙ кІҪкі  лӢӨмқҙм–јлЎңк·ё н‘ңмӢң
                                        showPtpipWarning = true
                                        return@BottomNavigationItem
                                    }

                                    if (screen.route == "settings") {
                                        onSettingsClick()
                                    } else {
                                        navController.navigate(screen.route) {
                                            popUpTo(navController.graph.findStartDestination().id) {
                                                saveState = true
                                            }
                                            launchSingleTop = true
                                            restoreState = true
                                        }
                                    }
                                },
                                selectedContentColor = MaterialTheme.colors.primary,
                                unselectedContentColor = MaterialTheme.colors.onSurface.copy(alpha = 0.6f)
                            )
                        }
                    }
                }
            },
            contentWindowInsets = WindowInsets.safeDrawing
        ) { innerPadding ->
            NavHost(
                navController,
                startDestination = BottomNavItem.CameraControl.route,
                Modifier.padding(
                    if (isFullscreen) PaddingValues(0.dp) else innerPadding
                )
            ) {
                composable(BottomNavItem.PhotoPreview.route) { PhotoPreviewScreen() }
                composable(BottomNavItem.CameraControl.route) {
                    // AP лӘЁл“ңмҷҖ USB лӘЁл“ң лӘЁл‘җ лҸҷмқјн•ң CameraControlScreen мӮ¬мҡ©
                    CameraControlScreen(
                        viewModel = cameraViewModel, // м „м—ӯ ViewModel м „лӢ¬
                        onFullscreenChange = { isFullscreen = it }
                    )
                }
                composable(BottomNavItem.ServerPhotos.route) { MyPhotosScreen() }
                // м„Өм •мқҖ лі„лҸ„ м•ЎнӢ°л№„нӢ°лЎң мІҳлҰ¬н•ҳлҜҖлЎң м—¬кё°м„ң м ңмҷё
            }
        }

        // PTPIP кІҪкі  лӢӨмқҙм–јлЎңк·ё
        if (showPtpipWarning) {
            androidx.compose.material.AlertDialog(
                onDismissRequest = { showPtpipWarning = false },
                title = {
                    Text(
                        "Wi-Fi м—°кІ° мӨ‘мһ…лӢҲлӢӨ",
                        style = MaterialTheme.typography.h6,
                        fontWeight = androidx.compose.ui.text.font.FontWeight.Bold,
                        color = MaterialTheme.colors.primary
                    )
                },
                text = {
                    Column {
                        Text(
                            "нҳ„мһ¬ м№ҙл©”лқјк°Җ Wi-FiлЎң м—°кІ°лҗҳм–ҙ мһҲм–ҙ мӮ¬м§„ лҜёлҰ¬ліҙкё°лҘј мӮ¬мҡ©н•  мҲҳ м—ҶмҠөлӢҲлӢӨ.",
                            style = MaterialTheme.typography.body1
                        )
                        Spacer(modifier = Modifier.height(16.dp))
                        Text(
                            "рҹ’Ў мӮ¬м§„ лҜёлҰ¬ліҙкё°лҘј мӮ¬мҡ©н•ҳл Өл©ҙ:",
                            style = MaterialTheme.typography.body2,
                            fontWeight = androidx.compose.ui.text.font.FontWeight.Bold,
                            color = MaterialTheme.colors.primary
                        )
                        Spacer(modifier = Modifier.height(8.dp))
                        Text(
                            "1пёҸвғЈ м№ҙл©”лқјмқҳ Wi-Fi м—°кІ°мқ„ н•ҙм ңн•ҙмЈјм„ёмҡ”\n" +
                                    "2пёҸвғЈ USB мјҖмқҙлё”лЎң м№ҙл©”лқјлҘј м—°кІ°н•ҙмЈјм„ёмҡ”\n" +
                                    "3пёҸвғЈ м№ҙл©”лқјлҘј PC лӘЁл“ңлЎң м„Өм •н•ҙмЈјм„ёмҡ”",
                            style = MaterialTheme.typography.body2,
                            color = MaterialTheme.colors.onSurface.copy(alpha = 0.8f)
                        )
                        Spacer(modifier = Modifier.height(12.dp))
                        Text(
                            "Wi-Fi м—°кІ°м—җм„ңлҠ” 'м№ҙл©”лқј м ңм–ҙ' нғӯмқ„ мқҙмҡ©н•ҙмЈјм„ёмҡ”! рҹ“·",
                            style = MaterialTheme.typography.caption,
                            color = MaterialTheme.colors.primary,
                            fontWeight = androidx.compose.ui.text.font.FontWeight.Medium
                        )
                    }
                },
                confirmButton = {
                    androidx.compose.material.TextButton(
                        onClick = { showPtpipWarning = false }
                    ) {
                        Text("м•ҢкІ мҠөлӢҲлӢӨ")
                    }
                },
                properties = androidx.compose.ui.window.DialogProperties(
                    dismissOnBackPress = true,
                    dismissOnClickOutside = true
                )
            )
        }

        // м№ҙл©”лқј кё°лҠҘ м ңн•ң м•ҲлӮҙ лӢӨмқҙм–јлЎңк·ё 
        if (cameraUiState.cameraFunctionLimitation != null) {
            AlertDialog(
                onDismissRequest = { 
                    // н•ң лІҲл§Ң н‘ңмӢң нӣ„ лӢ«кё°
                    cameraViewModel.clearCameraFunctionLimitation()
                },
                title = { 
                    Row(
                        verticalAlignment = Alignment.CenterVertically,
                        horizontalArrangement = Arrangement.spacedBy(8.dp)
                    ) {
                        Icon(
                            imageVector = Icons.Default.Info,
                            contentDescription = "м •ліҙ",
                            tint = MaterialTheme.colorScheme.primary
                        )
                        Text("м№ҙл©”лқј кё°лҠҘ м•ҲлӮҙ")
                    }
                },
                text = {
                    Column(
                        verticalArrangement = Arrangement.spacedBy(12.dp)
                    ) {
                        Text(
                            text = cameraUiState.cameraFunctionLimitation,
                            style = MaterialTheme.typography.bodyMedium
                        )
                        
                        if (cameraUiState.connectedCameraModel != null) {
                            HorizontalDivider()
                            
                            Column(verticalArrangement = Arrangement.spacedBy(4.dp)) {
                                Text(
                                    text = "м—°кІ°лҗң м№ҙл©”лқј:",
                                    style = MaterialTheme.typography.labelSmall,
                                    color = MaterialTheme.colorScheme.onSurfaceVariant
                                )
                                Text(
                                    text = cameraUiState.connectedCameraModel,
                                    style = MaterialTheme.typography.bodySmall,
                                    fontWeight = FontWeight.Bold
                                )
                            }
                        }
                    }
                },
                confirmButton = {
                    Button(
                        onClick = { 
                            cameraViewModel.clearCameraFunctionLimitation()
                        }
                    ) {
                        Text("нҷ•мқё")
                    }
                }
            )
        }
        
        // Nikon STA лӘЁл“ң кІҪкі  лӢӨмқҙм–јлЎңк·ё 
        if (cameraUiState.showNikonStaWarning && isPtpipConnected && !cameraUiState.cameraFunctionLimitation.isNullOrEmpty()) {
            AlertDialog(
                onDismissRequest = { 
                    cameraViewModel.dismissNikonStaWarning()
                },
                title = {
                    Row(
                        verticalAlignment = Alignment.CenterVertically,
                        horizontalArrangement = Arrangement.spacedBy(8.dp)
                    ) {
                        Icon(
                            imageVector = Icons.Default.Warning,
                            contentDescription = "кІҪкі ",
                            tint = MaterialTheme.colorScheme.error
                        )
                        Text("Nikon STA лӘЁл“ң")
                    }
                },
                text = {
                    Column(verticalArrangement = Arrangement.spacedBy(12.dp)) {
                        Text("Nikon м№ҙл©”лқјк°Җ STA лӘЁл“ңлЎң к°җм§Җлҗҳм—ҲмҠөлӢҲлӢӨ.")
                        Text("м№ҙл©”лқј LCDм—җм„ң 'м—°кІ° н—Ҳмҡ©'мқ„ лҲҢлҹ¬мЈјм„ёмҡ”.")
                        Text(
                            text = "лҢҖкё° мӢңк°„: мөңлҢҖ 30мҙҲ",
                            style = MaterialTheme.typography.bodySmall,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                    }
                },
                confirmButton = {
                    Button(onClick = { cameraViewModel.dismissNikonStaWarning() }) {
                        Text("нҷ•мқё")
                    }
                }
            )
        }

        // USB м—°кІ° л°Ҹ мҙҲкё°нҷ” мғҒнғңм—җ л”°лҘё UI лё”лЎңнӮ№ мҳӨлІ„л Ҳмқҙ
        val shouldShowOverlay =
            globalConnectionState.ptpipConnectionState == PtpipConnectionState.CONNECTING ||
            connectionStatusMessage.contains("мҙҲкё°нҷ” мӨ‘") ||
            cameraUiState.isUsbInitializing ||
                cameraUiState.isCameraInitializing

        if (shouldShowOverlay) {
            val overlayMessage = when {
                cameraUiState.isCameraInitializing -> "м№ҙл©”лқј мқҙлІӨнҠё мҙҲкё°нҷ” мӨ‘..."
                cameraUiState.isUsbInitializing -> cameraUiState.usbInitializationMessage
                    ?: "USB м№ҙл©”лқј мҙҲкё°нҷ” мӨ‘..."

                else -> connectionStatusMessage
            }

            LogcatManager.d("MainActivity", " UI лё”лЎңнӮ№ мҳӨлІ„л Ҳмқҙ н‘ңмӢң: $overlayMessage")
            LogcatManager.d(
                "MainActivity", "лё”лЎңнӮ№ мЎ°кұҙ - PTPм—°кІ°:${globalConnectionState.ptpipConnectionState}, " +
                        "л©”мӢңм§ҖмҙҲкё°нҷ”:${connectionStatusMessage.contains("мҙҲкё°нҷ” мӨ‘")}, " +
                        "USBмҙҲкё°нҷ”:${cameraUiState.isUsbInitializing}, " +
                        "м№ҙл©”лқјмҙҲкё°нҷ”:${cameraUiState.isCameraInitializing}"
            )

            UsbInitializationOverlay(message = overlayMessage)
        } else {
            // мҳӨлІ„л Ҳмқҙк°Җ мӮ¬лқјм§Ҳ л•ҢлҸ„ лЎңк·ё м¶ңл Ҙ
            LaunchedEffect(Unit) {
                LogcatManager.d("MainActivity", " UI лё”лЎңнӮ№ мҳӨлІ„л Ҳмқҙ н•ҙм ңлҗЁ")
                LogcatManager.d(
                    "MainActivity",
                    "н•ҙм ң мЎ°кұҙ - PTPм—°кІ°:${globalConnectionState.ptpipConnectionState}, " +
                            "л©”мӢңм§ҖмҙҲкё°нҷ”:${connectionStatusMessage.contains("мҙҲкё°нҷ” мӨ‘")}, " +
                            "USBмҙҲкё°нҷ”:${cameraUiState.isUsbInitializing}, " +
                            "м№ҙл©”лқјмҙҲкё°нҷ”:${cameraUiState.isCameraInitializing}"
                )
            }
        }
    }
}

@AndroidEntryPoint
class MainActivity : ComponentActivity() {

    private var batteryDialogShown = false

    @Inject
    lateinit var usbCameraManager: UsbCameraManager

    @Inject
    lateinit var globalManager: CameraConnectionGlobalManager

    @Inject
    lateinit var getSubscriptionUseCase: GetSubscriptionUseCase

    // к¶Ңн•ң мҡ”мІӯ лҹ°мІҳ
    private val storagePermissionLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { permissions ->
        val allGranted = permissions.all { it.value }
        if (allGranted) {
            LogcatManager.d("MainActivity", "лӘЁл“  м ҖмһҘмҶҢ к¶Ңн•ңмқҙ мҠ№мқёлҗЁ")
        } else {
            LogcatManager.w("MainActivity", "мқјл¶Җ м ҖмһҘмҶҢ к¶Ңн•ңмқҙ кұ°л¶ҖлҗЁ: $permissions")
        }
    }

    companion object {
        private const val TAG = "MainActivity"

        /**
         * м•ұмқ„ мҷ„м „нһҲ мһ¬мӢңмһ‘н•ҳлҠ” н•ЁмҲҳ
         */
        fun forceRestartApp(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "м•ұ к°•м ң мһ¬мӢңмһ‘ мӢңмһ‘")

                // 1. лЁјм Җ Activity мғҒнғң м •лҰ¬
                activity.finishAffinity()

                // 2. л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬лҘј л°ұк·ёлқјмҡҙл“ң мҠӨл Ҳл“ңм—җм„ң мҲҳн–ү
                Thread {
                    try {
                        LogcatManager.d(TAG, "closeCamera нҳём¶ң")
                        com.inik.camcon.CameraNative.closeCamera()
                        com.inik.camcon.CameraNative.closeLogFile()
                        LogcatManager.d(TAG, "л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мҷ„лЈҢ")
                    } catch (e: Exception) {
                        LogcatManager.w(TAG, "л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мӨ‘ мҳӨлҘҳ", e)
                    }
                }.start()

                // 3. лҚ” кёҙ м§Җм—° нӣ„ мһ¬мӢңмһ‘ мӢӨн–ү (л„ӨмқҙнӢ°лёҢ м •лҰ¬ мҷ„лЈҢ лҢҖкё°)
                android.os.Handler(android.os.Looper.getMainLooper()).postDelayed({
                    try {
                        LogcatManager.d(TAG, "м•ұ мһ¬мӢңмһ‘ мӢӨн–ү")

                        // мһ¬мӢңмһ‘ Intent мғқм„ұ
                        val restartIntent = Intent(activity, MainActivity::class.java).apply {
                            addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                            addFlags(Intent.FLAG_ACTIVITY_CLEAR_TASK)
                            addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP)
                            addFlags(Intent.FLAG_ACTIVITY_SINGLE_TOP) // м¶”к°Җ
                        }

                        activity.startActivity(restartIntent)

                        // н”„лЎңм„ёмҠӨ мў…лЈҢлҠ” лҚ” кёҙ м§Җм—° нӣ„ мӢӨн–ү
                        android.os.Handler(android.os.Looper.getMainLooper()).postDelayed({
                            LogcatManager.d(TAG, "н”„лЎңм„ёмҠӨ мў…лЈҢ мӢӨн–ү")
                            android.os.Process.killProcess(android.os.Process.myPid())
                        }, 1000) // 1мҙҲ нӣ„ н”„лЎңм„ёмҠӨ мў…лЈҢ

                    } catch (e: Exception) {
                        LogcatManager.e(TAG, "мһ¬мӢңмһ‘ мӢӨн–ү мӨ‘ мҳӨлҘҳ", e)
                        // Fallback: PackageManager мӮ¬мҡ©
                        restartWithPackageManager(activity)
                    }
                }, 2000) // 2мҙҲ м§Җм—°мңјлЎң л„ӨмқҙнӢ°лёҢ м •лҰ¬ мҷ„лЈҢ лҢҖкё°

                LogcatManager.d(TAG, "мһ¬мӢңмһ‘ мҳҲм•Ҫ мҷ„лЈҢ")

            } catch (e: Exception) {
                LogcatManager.e(TAG, "м•ұ мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                // мҳӨлҘҳ л°ңмғқ мӢң PackageManager мһ¬мӢңмһ‘ мӢңлҸ„
                restartWithPackageManager(activity)
            }
        }

        /**
         * PackageManagerлҘј мӮ¬мҡ©н•ң мһ¬мӢңмһ‘ (Fallback)
         */
        private fun restartWithPackageManager(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "PackageManager мһ¬мӢңмһ‘ мӢңлҸ„")
                val packageManager = activity.packageManager
                val restartIntent = packageManager.getLaunchIntentForPackage(activity.packageName)

                if (restartIntent != null) {
                    restartIntent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                    restartIntent.addFlags(Intent.FLAG_ACTIVITY_CLEAR_TASK)
                    restartIntent.addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP)

                    activity.startActivity(restartIntent)
                    activity.finishAffinity()
                    android.os.Process.killProcess(android.os.Process.myPid())
                } else {
                    LogcatManager.e(TAG, "PackageManager мһ¬мӢңмһ‘ мӢӨнҢЁ - Intent м—ҶмқҢ")
                    activity.finishAffinity()
                    System.exit(0)
                }
            } catch (e: Exception) {
                LogcatManager.e(TAG, "PackageManager мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                activity.finishAffinity()
                System.exit(0)
            }
        }

        /**
         * к°„лӢЁн•ң м•ұ мһ¬мӢңмһ‘ (мӮ¬мҡ©мһҗ мҲҳлҸҷ мһ¬мӢңмһ‘ м•ҲлӮҙ)
         */
        fun simpleRestartApp(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "к°„лӢЁн•ң м•ұ мһ¬мӢңмһ‘ мӢңмһ‘")

                // л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬
                Thread {
                    try {
                        com.inik.camcon.CameraNative.closeCamera()
                        com.inik.camcon.CameraNative.closeLogFile()
                        LogcatManager.d(TAG, "к°„лӢЁ мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мҷ„лЈҢ")
                    } catch (e: Exception) {
                        LogcatManager.w(TAG, "к°„лӢЁ мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мӨ‘ мҳӨлҘҳ", e)
                    }
                }.start()

                // 0.5мҙҲ нӣ„ м•ұ мў…лЈҢ (мӮ¬мҡ©мһҗк°Җ мҲҳлҸҷмңјлЎң мһ¬мӢңмһ‘н•ҙм•ј н•Ё)
                android.os.Handler(android.os.Looper.getMainLooper()).postDelayed({
                    LogcatManager.d(TAG, "м•ұ мў…лЈҢ - мӮ¬мҡ©мһҗ мҲҳлҸҷ мһ¬мӢңмһ‘ н•„мҡ”")
                    activity.finishAffinity()
                    android.os.Process.killProcess(android.os.Process.myPid())
                }, 500)

            } catch (e: Exception) {
                LogcatManager.e(TAG, "к°„лӢЁн•ң м•ұ мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                activity.finishAffinity()
                android.os.Process.killProcess(android.os.Process.myPid())
            }
        }

        /**
         * мӢңмҠӨн…ң мһ¬мӢңмһ‘ л©”м»ӨлӢҲмҰҳмқ„ мӮ¬мҡ©н•ң м•Ҳм „н•ң мһ¬мӢңмһ‘
         */
        fun systemRestartApp(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "мӢңмҠӨн…ң мһ¬мӢңмһ‘ мӢңмһ‘")

                // 1. makeRestartActivityTaskлҘј мӮ¬мҡ©н•ң мҰүмӢң мһ¬мӢңмһ‘
                val packageManager = activity.packageManager
                val intent = packageManager.getLaunchIntentForPackage(activity.packageName)
                val componentName = intent?.component

                if (componentName != null) {
                    val mainIntent = Intent.makeRestartActivityTask(componentName)
                    activity.startActivity(mainIntent)
                    LogcatManager.d(TAG, "makeRestartActivityTask мӢӨн–ү мҷ„лЈҢ")
                } else {
                    LogcatManager.e(TAG, "ComponentNameмқ„ м°ҫмқ„ мҲҳ м—ҶмқҢ")
                    // Fallback: кё°мЎҙ л°©мӢқ
                    restartWithPackageManager(activity)
                    return
                }

                // 2. л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ (л°ұк·ёлқјмҡҙл“ңм—җм„ң)
                Thread {
                    try {
                        com.inik.camcon.CameraNative.closeCamera()
                        com.inik.camcon.CameraNative.closeLogFile()
                        LogcatManager.d(TAG, "мӢңмҠӨн…ң мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мҷ„лЈҢ")
                    } catch (e: Exception) {
                        LogcatManager.w(TAG, "мӢңмҠӨн…ң мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мӨ‘ мҳӨлҘҳ", e)
                    }
                }.start()

                // 3. н”„лЎңм„ёмҠӨ мў…лЈҢ
                kotlin.system.exitProcess(0)

            } catch (e: Exception) {
                LogcatManager.e(TAG, "мӢңмҠӨн…ң мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                // Fallback: кё°мЎҙ л°©мӢқ
                restartWithPackageManager(activity)
            }
        }

        /**
         * мҰүмӢң мһ¬мӢңмһ‘ (к°ҖмһҘ л№ лҘё л°©лІ•)
         */
        fun instantRestartApp(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "мҰүмӢң мһ¬мӢңмһ‘ мӢңмһ‘")

                // 1. makeRestartActivityTaskлҘј мӮ¬мҡ©н•ң мҰүмӢң мһ¬мӢңмһ‘
                val packageManager = activity.packageManager
                val intent = packageManager.getLaunchIntentForPackage(activity.packageName)
                val componentName = intent?.component

                if (componentName != null) {
                    val mainIntent = Intent.makeRestartActivityTask(componentName)
                    activity.startActivity(mainIntent)
                    LogcatManager.d(TAG, "мҰүмӢң мһ¬мӢңмһ‘: makeRestartActivityTask мӢӨн–ү мҷ„лЈҢ")
                } else {
                    LogcatManager.e(TAG, "мҰүмӢң мһ¬мӢңмһ‘: ComponentNameмқ„ м°ҫмқ„ мҲҳ м—ҶмқҢ")
                    // Fallback: кё°мЎҙ л°©мӢқ
                    val restartIntent = Intent(activity, MainActivity::class.java).apply {
                        addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                        addFlags(Intent.FLAG_ACTIVITY_CLEAR_TASK)
                        addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP)
                    }
                    activity.startActivity(restartIntent)
                }

                // 2. л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ (л°ұк·ёлқјмҡҙл“ңм—җм„ң)
                Thread {
                    try {
                        com.inik.camcon.CameraNative.closeCamera()
                        com.inik.camcon.CameraNative.closeLogFile()
                        LogcatManager.d(TAG, "мҰүмӢң мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мҷ„лЈҢ")
                    } catch (e: Exception) {
                        LogcatManager.w(TAG, "мҰүмӢң мһ¬мӢңмһ‘: л„ӨмқҙнӢ°лёҢ лҰ¬мҶҢмҠӨ м •лҰ¬ мӨ‘ мҳӨлҘҳ", e)
                    }
                }.start()

                // 3. н”„лЎңм„ёмҠӨ мў…лЈҢ
                kotlin.system.exitProcess(0)

            } catch (e: Exception) {
                LogcatManager.e(TAG, "мҰүмӢң мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                // Fallback: кё°мЎҙ л°©мӢқ
                try {
                    activity.finishAffinity()
                    kotlin.system.exitProcess(0)
                } catch (ex: Exception) {
                    android.os.Process.killProcess(android.os.Process.myPid())
                }
            }
        }

        /**
         * м№ҙл©”лқј м •лҰ¬ мҷ„лЈҢ нӣ„ м•ұмқ„ мһ¬мӢңмһ‘н•ҳлҠ” м•Ҳм „н•ң л°©лІ•
         */
        fun restartAppAfterCameraCleanup(activity: ComponentActivity) {
            try {
                LogcatManager.d(TAG, "м№ҙл©”лқј м •лҰ¬ нӣ„ м•ұ мһ¬мӢңмһ‘ мӢңмһ‘")

                // м№ҙл©”лқј м •лҰ¬ мҷ„лЈҢ мҪңл°ұмқ„ мӮ¬мҡ©н•ң м•Ҳм „н•ң мһ¬мӢңмһ‘
                com.inik.camcon.CameraNative.closeCameraAsync(
                    object : com.inik.camcon.CameraCleanupCallback {
                        override fun onCleanupComplete(success: Boolean, message: String) {
                            LogcatManager.d(TAG, "м№ҙл©”лқј м •лҰ¬ мҷ„лЈҢ: success=$success, message=$message")

                            // л©”мқё мҠӨл Ҳл“ңм—җм„ң мһ¬мӢңмһ‘ мӢӨн–ү
                            android.os.Handler(android.os.Looper.getMainLooper()).post {
                                try {
                                    // лЎңк·ё нҢҢмқјлҸ„ лӢ«кё°
                                    com.inik.camcon.CameraNative.closeLogFile()

                                    // мӢңмҠӨн…ң мһ¬мӢңмһ‘ л©”м»ӨлӢҲмҰҳ мӮ¬мҡ©
                                    val packageManager = activity.packageManager
                                    val intent = packageManager.getLaunchIntentForPackage(activity.packageName)
                                    val componentName = intent?.component

                                    if (componentName != null) {
                                        val mainIntent = Intent.makeRestartActivityTask(componentName)
                                        activity.startActivity(mainIntent)
                                        LogcatManager.d(TAG, "м№ҙл©”лқј м •лҰ¬ нӣ„ мһ¬мӢңмһ‘ мӢӨн–ү мҷ„лЈҢ")
                                    } else {
                                        // Fallback
                                        val restartIntent = Intent(activity, MainActivity::class.java).apply {
                                            addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                                            addFlags(Intent.FLAG_ACTIVITY_CLEAR_TASK)
                                            addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP)
                                        }
                                        activity.startActivity(restartIntent)
                                    }

                                    // н”„лЎңм„ёмҠӨ м •лҰ¬
                                    activity.finishAffinity()
                                    kotlin.system.exitProcess(0)

                                } catch (e: Exception) {
                                    LogcatManager.e(TAG, "м№ҙл©”лқј м •лҰ¬ нӣ„ мһ¬мӢңмһ‘ мӢӨн–ү мӨ‘ мҳӨлҘҳ", e)
                                    // Fallback: кё°мЎҙ л°©мӢқ мӮ¬мҡ©
                                    systemRestartApp(activity)
                                }
                            }
                        }
                    }
                )

            } catch (e: Exception) {
                LogcatManager.e(TAG, "м№ҙл©”лқј м •лҰ¬ нӣ„ мһ¬мӢңмһ‘ мӨ‘ мҳӨлҘҳ", e)
                // Fallback: кё°мЎҙ л°©мӢқ мӮ¬мҡ©
                systemRestartApp(activity)
            }
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ(мқҙлІӨнҠё лҰ¬мҠӨл„Ҳ мң м§Җ) мӢңмһ‘
        try {
            val serviceIntent = Intent(this, BackgroundSyncService::class.java)
            ContextCompat.startForegroundService(this, serviceIntent)
            LogcatManager.d(TAG, "BackgroundSyncService мӢңмһ‘ мҡ”мІӯлҗЁ")
        } catch (e: Exception) {
            LogcatManager.w(TAG, "BackgroundSyncService мӢңмһ‘ мӢӨнҢЁ", e)
        }

        // мӮ¬мҡ©мһҗ кө¬лҸ… нӢ°м–ҙ лЎңк·ё м¶ңл Ҙ
        lifecycleScope.launch {
            try {
                // мғҒм„ён•ң нӢ°м–ҙ м •ліҙлҘј н•ң лІҲл§Ң лЎңк·ём—җ м¶ңл Ҙ
                getSubscriptionUseCase.logCurrentTier()
            } catch (e: Exception) {
                LogcatManager.e(TAG, "мӮ¬мҡ©мһҗ нӢ°м–ҙ м •ліҙ лЎңл“ң мӢӨнҢЁ", e)
            }
        }

        // м ҖмһҘмҶҢ к¶Ңн•ң мҡ”мІӯ
        requestStoragePermissions()

        // USB л””л°”мқҙмҠӨ м—°кІ° Intent мІҳлҰ¬лҘј л№„лҸҷкё°лЎң мҲҳн–ү
        lifecycleScope.launch(Dispatchers.IO) {
            handleUsbIntent(intent)

            // м¶”к°Җ: м•ұ мӢңмһ‘ мӢң мқҙлҜё м—°кІ°лҗң USB л””л°”мқҙмҠӨ кІҖмғү
            delay(500) // UI мҙҲкё°нҷ” лҢҖкё°
            checkAndInitializeUsbDevices()
        }

        setContent {
            val appSettingsViewModel: AppSettingsViewModel = hiltViewModel()
            val themeMode by appSettingsViewModel.themeMode.collectAsState()

            var showBatteryDialog by remember { mutableStateOf(false) }

            // н•ңлІҲл§Ң лӢӨмқҙм–јлЎңк·ёлҘј лқ„мӣҖ
            LaunchedEffect(Unit) {
                // check immediately after Compose composition
                if (shouldShowCameraConnectionOptimizationDialog() && !batteryDialogShown) {
                    showBatteryDialog = true
                    batteryDialogShown = true
                }
            }

            CamConTheme(themeMode = themeMode) {
                Surface {
                    if (showBatteryDialog) {
                        CameraConnectionOptimizationDialog(
                            onDismissRequest = {
                                showBatteryDialog = false
                                markCameraConnectionOptimizationDialogShown()
                            },
                            onGoToSettings = {
                                // л°°н„°лҰ¬ мөңм Ғнҷ” мҳҲмҷё м„Өм • нҷ”л©ҙмңјлЎң мқҙлҸҷ
                                openBatteryOptimizationSettings()
                                showBatteryDialog = false
                                markCameraConnectionOptimizationDialogShown()
                            }
                        )
                    }
                    MainScreen(
                        onSettingsClick = {
                            startActivity(Intent(this, SettingsActivity::class.java))
                        },
                        globalManager = globalManager
                    )
                }
            }
        }
    }

    override fun onNewIntent(intent: Intent) {
        super.onNewIntent(intent)
        setIntent(intent)
        // USB Intent мІҳлҰ¬лҘј л№„лҸҷкё°лЎң мҲҳн–ү
        lifecycleScope.launch(Dispatchers.IO) {
            handleUsbIntent(intent)
        }
    }

    private suspend fun handleUsbIntent(intent: Intent) = withContext(Dispatchers.IO) {
        when (intent.action) {
            UsbManager.ACTION_USB_DEVICE_ATTACHED -> {
                val device: UsbDevice? =
                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                        intent.getParcelableExtra(UsbManager.EXTRA_DEVICE, UsbDevice::class.java)
                    } else {
                        @Suppress("DEPRECATION")
                        intent.getParcelableExtra(UsbManager.EXTRA_DEVICE)
                    }
                device?.let {
                    LogcatManager.d(TAG, "USB м№ҙл©”лқј л””л°”мқҙмҠӨк°Җ м—°кІ°лҗЁ: ${it.deviceName}")
                    LogcatManager.d(
                        TAG,
                        "м ңмЎ°мӮ¬ID: 0x${it.vendorId.toString(16)}, м ңн’ҲID: 0x${it.productId.toString(16)}"
                    )

                    // мҰүмӢң к¶Ңн•ң мҡ”мІӯ
                    if (!isUsbCameraDevice(it)) {
                        LogcatManager.d(TAG, "м№ҙл©”лқј л””л°”мқҙмҠӨк°Җ м•„лӢҳ")
                        return@withContext
                    }

                    LogcatManager.d(TAG, "м№ҙл©”лқј л””л°”мқҙмҠӨ нҷ•мқёлҗЁ, к¶Ңн•ң мҡ”мІӯ")

                    withContext(Dispatchers.Main) {
                        usbCameraManager.requestPermission(it)
                    }
                }
            }
            UsbManager.ACTION_USB_DEVICE_DETACHED -> {
                val device: UsbDevice? =
                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                        intent.getParcelableExtra(UsbManager.EXTRA_DEVICE, UsbDevice::class.java)
                    } else {
                        @Suppress("DEPRECATION")
                        intent.getParcelableExtra(UsbManager.EXTRA_DEVICE)
                    }
                device?.let {
                    LogcatManager.d(TAG, "USB л””л°”мқҙмҠӨк°Җ л¶„лҰ¬лҗЁ: ${it.deviceName}")
                }
            }
        }
    }

    private fun isUsbCameraDevice(device: UsbDevice): Boolean {
        // PTP нҒҙлһҳмҠӨ нҷ•мқё
        for (i in 0 until device.interfaceCount) {
            val usbInterface = device.getInterface(i)
            if (usbInterface.interfaceClass == 6) { // Still Image Capture Device
                return true
            }
        }

        // м•Ңл Өм§„ м№ҙл©”лқј м ңмЎ°мӮ¬ нҷ•мқё
        val knownCameraVendors =
            listOf(0x04A9, 0x04B0, 0x054C, 0x04CB) // Canon, Nikon, Sony, Fujifilm
        return device.vendorId in knownCameraVendors
    }

    override fun onResume() {
        super.onResume()
        LogcatManager.d(TAG, " м•ұ нҸ¬к·ёлқјмҡҙл“ң м§„мһ… - л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ мғҒнғң нҷ•мқё")

        // м•ұмқҙ лӢӨмӢң нҷңм„ұнҷ”лҗ  л•Ң USB мғҒнғңл§Ң нҷ•мқё (л””л°”мқҙмҠӨ мһ¬кІҖмғүмқҖ н•ҳм§Җ м•ҠмқҢ)
        lifecycleScope.launch(Dispatchers.IO) {
            checkUsbPermissionStatus()
        }
    }

    override fun onPause() {
        super.onPause()
        LogcatManager.d(TAG, " м•ұ л°ұк·ёлқјмҡҙл“ң м§„мһ… - л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ нҷ•мқё")

        // м•ұмқҙ л°ұк·ёлқјмҡҙл“ңлЎң мқҙлҸҷн•  л•Ң л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨк°Җ мӢӨн–ү мӨ‘мқём§Җ нҷ•мқё
        lifecycleScope.launch(Dispatchers.IO) {
            try {
                // л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨк°Җ мӢӨн–ү мӨ‘мқём§Җ нҷ•мқё
                val isServiceRunning = isServiceRunning(BackgroundSyncService::class.java)
                if (!isServiceRunning) {
                    LogcatManager.d(TAG, " л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ мһ¬мӢңмһ‘ н•„мҡ”")
                    withContext(Dispatchers.Main) {
                        BackgroundSyncService.startService(this@MainActivity)
                    }
                } else {
                    LogcatManager.d(TAG, " л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ мқҙлҜё мӢӨн–ү мӨ‘")
                }
            } catch (e: Exception) {
                LogcatManager.w(TAG, "л°ұк·ёлқјмҡҙл“ң м„ңл№„мҠӨ мғҒнғң нҷ•мқё мӢӨнҢЁ", e)
            }
        }
    }

    /**
     * м„ңл№„мҠӨ мӢӨн–ү мғҒнғң нҷ•мқё
     */
    private fun isServiceRunning(serviceClass: Class<*>): Boolean {
        return try {
            val manager = getSystemService(Context.ACTIVITY_SERVICE) as android.app.ActivityManager
            for (service in manager.getRunningServices(Int.MAX_VALUE)) {
                if (serviceClass.name == service.service.className) {
                    LogcatManager.d(TAG, "м„ңл№„мҠӨ мӢӨн–ү мӨ‘: ${serviceClass.simpleName}")
                    return true
                }
            }
            LogcatManager.d(TAG, "м„ңл№„мҠӨ мӢӨн–үлҗҳм§Җ м•ҠмқҢ: ${serviceClass.simpleName}")
            false
        } catch (e: Exception) {
            LogcatManager.w(TAG, "м„ңл№„мҠӨ мғҒнғң нҷ•мқё мӢӨнҢЁ", e)
            false
        }
    }

    private suspend fun checkUsbPermissionStatus() = withContext(Dispatchers.IO) {
        try {
            // мқҙлҜё м—°кІ°лҗң л””л°”мқҙмҠӨк°Җ мһҲлҠ”м§Җ нҷ•мқё (мғҲлЎң кІҖмғүн•ҳм§Җ м•ҠмқҢ)
            val currentDevice = usbCameraManager.getCurrentDevice()

            if (currentDevice != null) {
                LogcatManager.d(TAG, "м•ұ мһ¬к°ң мӢң кё°мЎҙ м—°кІ°лҗң л””л°”мқҙмҠӨ нҷ•мқё: ${currentDevice.deviceName}")

                // к¶Ңн•ң мғҒнғңл§Ң нҷ•мқё
                if (!usbCameraManager.hasUsbPermission.value) {
                    LogcatManager.d(TAG, "кё°мЎҙ л””л°”мқҙмҠӨмқҳ к¶Ңн•ңмқҙ м—ҶмқҢ, к¶Ңн•ң мҡ”мІӯ: ${currentDevice.deviceName}")
                    withContext(Dispatchers.Main) {
                        usbCameraManager.requestPermission(currentDevice)
                    }
                } else {
                    LogcatManager.d(TAG, "кё°мЎҙ л””л°”мқҙмҠӨм—җ к¶Ңн•ңмқҙ мһҲмқҢ: ${currentDevice.deviceName}")
                    // к¶Ңн•ң мһҲмқҢ + м•„м§Ғ л„ӨмқҙнӢ°лёҢ м—°кІ°мқҙ м—ҶлӢӨл©ҙ мһҗлҸҷ мҙҲкё°нҷ” нҠёлҰ¬кұ°
                    if (!usbCameraManager.isNativeCameraConnected.value) {
                        LogcatManager.d(TAG, "л„ӨмқҙнӢ°лёҢ м—°кІ° м—ҶмқҢ - мһҗлҸҷ мҙҲкё°нҷ” мӢңмһ‘: ${currentDevice.deviceName}")
                        withContext(Dispatchers.Main) {
                            usbCameraManager.connectToCamera(currentDevice)
                        }
                    }
                }
            } else {
                // м—°кІ°лҗң л””л°”мқҙмҠӨк°Җ м—Ҷмңјл©ҙ StateFlowлҘј нҶөн•ҙ нҷ•мқё
                // мәҗмӢңлҗң лӘ©лЎқмқҙ мһҲмқ„ кІғмқҙлҜҖлЎң л№ лҘҙкІҢ мІҳлҰ¬лҗЁ
                val devices = usbCameraManager.getCameraDevices()
                if (devices.isNotEmpty()) {
                    LogcatManager.d(TAG, "м•ұ мһ¬к°ң мӢң мәҗмӢңлҗң л””л°”мқҙмҠӨ лӘ©лЎқ нҷ•мқё: ${devices.size}к°ң")

                    val device = devices.first()
                    if (!usbCameraManager.hasUsbPermission.value) {
                        LogcatManager.d(TAG, "к¶Ңн•ңмқҙ м—ҶлҠ” л””л°”мқҙмҠӨ л°ңкІ¬, к¶Ңн•ң мҡ”мІӯ: ${device.deviceName}")
                        withContext(Dispatchers.Main) {
                            usbCameraManager.requestPermission(device)
                        }
                    } else {
                        LogcatManager.d(TAG, "м№ҙл©”лқј л””л°”мқҙмҠӨ м—°кІ°лҗЁ")
                        // к¶Ңн•ң мһҲмқҢ + м•„м§Ғ л„ӨмқҙнӢ°лёҢ м—°кІ°мқҙ м—ҶлӢӨл©ҙ мһҗлҸҷ мҙҲкё°нҷ” нҠёлҰ¬кұ°
                        if (!usbCameraManager.isNativeCameraConnected.value) {
                            LogcatManager.d(TAG, "л„ӨмқҙнӢ°лёҢ м—°кІ° м—ҶмқҢ - мһҗлҸҷ мҙҲкё°нҷ” мӢңмһ‘: ${device.deviceName}")
                            withContext(Dispatchers.Main) {
                                usbCameraManager.connectToCamera(device)
                            }
                        }
                    }
                } else {
                    LogcatManager.d(TAG, "м•ұ мһ¬к°ң мӢң USB м№ҙл©”лқј л””л°”мқҙмҠӨ м—ҶмқҢ")
                }
            }
        } catch (e: Exception) {
            LogcatManager.e(TAG, "USB к¶Ңн•ң мғҒнғң нҷ•мқё мӨ‘ мҳӨлҘҳ", e)
        }
    }

    private suspend fun checkAndInitializeUsbDevices() = withContext(Dispatchers.IO) {
        try {
            // USB л§ӨлӢҲм ҖлҘј мӮ¬мҡ©н•ҳм—¬ м—°кІ°лҗң л””л°”мқҙмҠӨ лӘ©лЎқ к°Җм ёмҳӨкё°
            val devices = usbCameraManager.getCameraDevices()

            // м—°кІ°лҗң л””л°”мқҙмҠӨ лӘ©лЎқмқҙ л№„м–ҙ мһҲмңјл©ҙ мў…лЈҢ
            if (devices.isEmpty()) {
                LogcatManager.d(TAG, "м—°кІ°лҗң USB м№ҙл©”лқј л””л°”мқҙмҠӨ м—ҶмқҢ")
                return@withContext
            }

            // м—°кІ°лҗң л””л°”мқҙмҠӨ мӨ‘ мІ« лІҲм§ё л””л°”мқҙмҠӨлҘј м„ нғқ
            val device = devices.first()

            // л””л°”мқҙмҠӨм—җ лҢҖн•ң к¶Ңн•ңмқҙ мһҲлҠ”м§Җ нҷ•мқё
            if (!usbCameraManager.hasUsbPermission.value) {
                LogcatManager.d(TAG, "л””л°”мқҙмҠӨм—җ лҢҖн•ң к¶Ңн•ңмқҙ м—ҶмқҢ, к¶Ңн•ң мҡ”мІӯ: ${device.deviceName}")
                withContext(Dispatchers.Main) {
                    usbCameraManager.requestPermission(device)
                }
            } else {
                LogcatManager.d(TAG, "л””л°”мқҙмҠӨм—җ лҢҖн•ң к¶Ңн•ңмқҙ мһҲмқҢ: ${device.deviceName}")
                // к¶Ңн•ң мһҲмқҢ + м•„м§Ғ л„ӨмқҙнӢ°лёҢ м—°кІ°мқҙ м—ҶлӢӨл©ҙ мһҗлҸҷ мҙҲкё°нҷ” нҠёлҰ¬кұ°
                if (!usbCameraManager.isNativeCameraConnected.value) {
                    LogcatManager.d(TAG, "л„ӨмқҙнӢ°лёҢ м—°кІ° м—ҶмқҢ - мһҗлҸҷ мҙҲкё°нҷ” мӢңмһ‘: ${device.deviceName}")
                    withContext(Dispatchers.Main) {
                        usbCameraManager.connectToCamera(device)
                    }
                }
            }
        } catch (e: Exception) {
            LogcatManager.e(TAG, "USB л””л°”мқҙмҠӨ мҙҲкё°нҷ” мӨ‘ мҳӨлҘҳ", e)
        }
    }

    /**
     * м ҖмһҘмҶҢ к¶Ңн•ң мҡ”мІӯ
     */
    private fun requestStoragePermissions() {
        val permissionsToRequest = mutableListOf<String>()

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            // Android 13+: м„ёл¶„нҷ”лҗң лҜёл””м–ҙ к¶Ңн•ң
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.READ_MEDIA_IMAGES)
                != PackageManager.PERMISSION_GRANTED
            ) {
                permissionsToRequest.add(Manifest.permission.READ_MEDIA_IMAGES)
            }
        } else {
            // Android 12 мқҙн•ҳ: кё°мЎҙ м ҖмһҘмҶҢ к¶Ңн•ң
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.READ_EXTERNAL_STORAGE)
                != PackageManager.PERMISSION_GRANTED
            ) {
                permissionsToRequest.add(Manifest.permission.READ_EXTERNAL_STORAGE)
            }
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.WRITE_EXTERNAL_STORAGE)
                != PackageManager.PERMISSION_GRANTED
            ) {
                permissionsToRequest.add(Manifest.permission.WRITE_EXTERNAL_STORAGE)
            }
        }

        if (permissionsToRequest.isNotEmpty()) {
            LogcatManager.d("MainActivity", "м ҖмһҘмҶҢ к¶Ңн•ң мҡ”мІӯ: $permissionsToRequest")
            storagePermissionLauncher.launch(permissionsToRequest.toTypedArray())
        } else {
            LogcatManager.d("MainActivity", "м ҖмһҘмҶҢ к¶Ңн•ңмқҙ мқҙлҜё мҠ№мқёлҗЁ")
        }
    }

    override fun onDestroy() {
        super.onDestroy()
        // Activityк°Җ мў…лЈҢлҗ  л•Ң USB л§ӨлӢҲм Җ м •лҰ¬
        try {
            // лӘ…мӢңм ҒмңјлЎң м№ҙл©”лқј м„ём…ҳ мў…лЈҢ - л°ұк·ёлқјмҡҙл“ң мҠӨл Ҳл“ңм—җм„ң м•Ҳм „н•ҳкІҢ мҲҳн–ү
            Thread {
                try {
                    LogcatManager.d(TAG, "onDestroy - closeCamera нҳём¶ң")
                    com.inik.camcon.CameraNative.closeCamera()
                    LogcatManager.d(TAG, "м№ҙл©”лқј м„ём…ҳ лӘ…мӢңм Ғ мў…лЈҢ мҷ„лЈҢ")
                } catch (e: Exception) {
                    LogcatManager.w(TAG, "м№ҙл©”лқј м„ём…ҳ мў…лЈҢ мӨ‘ мҳӨлҘҳ", e)
                }
            }.start()

            usbCameraManager.cleanup()
            globalManager.cleanup()

            // libgphoto2 лЎңк·ё нҢҢмқј лӢ«кё°лҸ„ л°ұк·ёлқјмҡҙл“ңм—җм„ң мҲҳн–ү
            Thread {
                try {
                    com.inik.camcon.CameraNative.closeLogFile()
                    LogcatManager.d(TAG, "libgphoto2 лЎңк·ё нҢҢмқј лӢ«кё° мҷ„лЈҢ")
                } catch (e: Exception) {
                    LogcatManager.w(TAG, "лЎңк·ё нҢҢмқј лӢ«кё° мӨ‘ мҳӨлҘҳ", e)
                }
            }.start()
        } catch (e: Exception) {
            LogcatManager.w(TAG, "л§ӨлӢҲм Җ м •лҰ¬ мӨ‘ мҳӨлҘҳ", e)
        }
    }

    /**
     * м№ҙл©”лқј м—°кІ° мөңм Ғнҷ” лӢӨмқҙм–јлЎңк·ё н‘ңмӢң м—¬л¶Җ нҷ•мқё
     */
    private fun shouldShowCameraConnectionOptimizationDialog(): Boolean {
        // м•ұ м„Өм№ҳ нӣ„ мІҳмқҢ мӢӨн–ү мӢңм—җл§Ң н‘ңмӢң + м•„м§Ғ л°°н„°лҰ¬ мөңм Ғнҷ” мҳҲмҷё лҜём Ғмҡ© мӢң л…ём¶ң
        val prefs = getSharedPreferences("app_preferences", Context.MODE_PRIVATE)
        val dialogShown = prefs.getBoolean("camera_connection_optimization_dialog_shown", false)
        return !dialogShown && !isIgnoringBatteryOptimizations()
    }

    /**
     * м№ҙл©”лқј м—°кІ° мөңм Ғнҷ” лӢӨмқҙм–јлЎңк·ё н‘ңмӢң мҷ„лЈҢ кё°лЎқ
     */
    private fun markCameraConnectionOptimizationDialogShown() {
        val prefs = getSharedPreferences("app_preferences", Context.MODE_PRIVATE)
        prefs.edit().putBoolean("camera_connection_optimization_dialog_shown", true).apply()
    }

    /**
     * л°°н„°лҰ¬ мөңм Ғнҷ”(Doze лӘЁл“ң) л¬ҙмӢң мғҒнғңмқём§Җ нҷ•мқё
     */
    private fun isIgnoringBatteryOptimizations(): Boolean {
        return try {
            val pm = getSystemService(Context.POWER_SERVICE) as PowerManager
            pm.isIgnoringBatteryOptimizations(packageName)
        } catch (e: Exception) {
            false
        }
    }

    /**
     * л°°н„°лҰ¬ мөңм Ғнҷ” мҳҲмҷё м„Өм • нҷ”л©ҙмңјлЎң мқҙлҸҷ
     */
    private fun openBatteryOptimizationSettings() {
        try {
            val intent =
                Intent(Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS)
            intent.data = Uri.parse("package:$packageName")
            startActivity(intent)
        } catch (e: Exception) {
            LogcatManager.e(TAG, "л°°н„°лҰ¬ мөңм Ғнҷ” мҳҲмҷё м„Өм • нҷ”л©ҙ мқҙлҸҷ мӢӨнҢЁ", e)
            // лҢҖмІҙ м Ҳм°Ё: м•ұ мғҒм„ё м •ліҙ нҷ”л©ҙ
            try {
                val intent = Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS)
                intent.data = Uri.parse("package:$packageName")
                startActivity(intent)
            } catch (ex: Exception) {
                LogcatManager.e(TAG, "APP мғҒм„ё м •ліҙ нҷ”л©ҙлҸ„ мқҙлҸҷ мӢӨнҢЁ", ex)
            }
        }
    }
}

/**
 * л©”мқё м•ЎнӢ°л№„нӢ° н”„лҰ¬л·°
 */
@Composable
fun MainActivityPreview() {
    CamConTheme {
        // н”„лҰ¬л·°мҡ© к°„лӢЁн•ң м»ҙнҸ¬л„ҢнҠё
        Scaffold(
            backgroundColor = MaterialTheme.colors.background
        ) {
            Box(
                modifier = Modifier
                    .fillMaxSize()
                    .padding(it),
                contentAlignment = androidx.compose.ui.Alignment.Center
            ) {
                Text(
                    text = "CamCon - л©”мқё нҷ”л©ҙ",
                    style = MaterialTheme.typography.h6
                )
            }
        }
    }
}
