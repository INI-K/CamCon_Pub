+/**
+ * ptp_nikon_advancedtransfer:
+ * params:	PTPParams*
+ *		p1			- request parameter (observed 0x2001 from Wireless Transmitter Utility)
+ *		data			- pointer to newly allocated response data
+ *		len			- length of response data
+ *
+ * Nikon "PC connection" transfer-queue pull (OC 0x9010). Returns the next queued
+ * transfer item: [u32 objecthandle][counted UTF-16LE path][counted UTF-16 capture/mod dates].
+ * Crucially, issuing this releases the infrastructure/STA AccessLock for that handle, so a
+ * subsequent standard GetObjectInfo/GetPartialObject succeeds (CamCon: physical-shutter Wi-Fi
+ * receive without 0x200F). Verified against WTU wire capture on Nikon Z6 V3.80.
+ *
+ * Return values: Some PTP_RC_* code.
+ **/
+uint16_t
+ptp_nikon_advancedtransfer (PTPParams* params, uint32_t p1, unsigned char** data, unsigned int *len)
+{
+	PTPContainer ptp;
+
+	PTP_CNT_INIT(ptp, PTP_OC_NIKON_AdvancedTransfer, p1);
+	return ptp_transaction(params, &ptp, PTP_DP_GETDATA, 0, data, len);
+}
+
+
+/**
+ * ptp_nikon_sta_approve:
+ * params:	PTPParams*
+ *
+ * Nikon STA(Wi-Fi / "PC connection") in-session connect approval, identical to
+ * Nikon's Wireless Transmitter Utility (verified by WTU wire capture, Z8 V3.10):
+ *	0x952b	StaMode init (data-in; returned list discarded)
+ *	0x935a	connect-approval request, param 0x2001
+ * On an unapproved client the camera returns a "hollow" DeviceInfo until this runs;
+ * afterwards it fires DeviceInfoChanged and exposes the full opcode/property set on
+ * THIS same session (only one PTP/IP session is allowed, so a separate-socket
+ * approve+teardown would lock the camera). Caller must re-read DeviceInfo after.
+ *
+ * Return values: the 0x935a (approval) PTP_RC_* code (PTP_RC_OK on success).
+ **/
+uint16_t
+ptp_nikon_sta_approve (PTPParams* params)
+{
+	PTPContainer	ptp;
+	unsigned char	*data = NULL;
+	unsigned int	len = 0;
+	uint16_t	ret;
+
+	PTP_CNT_INIT(ptp, PTP_OC_NIKON_StaModeInit);
+	ret = ptp_transaction(params, &ptp, PTP_DP_GETDATA, 0, &data, &len);
+	free (data);
+	if (ret != PTP_RC_OK)
+		return ret;
+
+	PTP_CNT_INIT(ptp, PTP_OC_NIKON_StaApprove, 0x2001);
+	return ptp_transaction(params, &ptp, PTP_DP_NODATA, 0, NULL, NULL);
+}
+
 
