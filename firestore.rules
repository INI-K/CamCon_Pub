rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 인증된 사용자인지 확인하는 함수
    function isAuthenticated() {
      return request.auth != null;
    }

    // 사용자 ID가 일치하는지 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 사용자가 ADMIN 티어인지 확인
    // 주의: match 경로 변수는 함수 내부에서 $(database)/$(userId) 로 바인딩해야 한다.
    // {database}/{userId} 로 쓰면 리터럴 경로가 되어 문서가 존재하지 않고 항상 false → 관리자 read 전멸.
    function isAdmin(userId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(userId)/subscriptions/current) &&
             get(/databases/$(database)/documents/users/$(userId)/subscriptions/current).data.tier == 'ADMIN';
    }

    // 현재 사용자가 ADMIN인지 확인
    function currentUserIsAdmin() {
      return isAdmin(request.auth.uid);
    }

    // 필드 변경 감지 함수
    function fieldChanged(fieldName) {
      return fieldName in request.resource.data.diff(resource.data).affectedKeys();
    }

    // 보호된 필드(구독 티어·추천 이력 등)가 변경되지 않았는지 확인.
    // referredBy/totalReferrals 를 포함하는 이유: 클라가 referredBy 를 리셋해
    // redeemReferralCode 의 '계정당 1회' 가드를 우회하는 구멍을 봉쇄한다(서버 Admin SDK 만 갱신).
    // referralCode 는 generateReferralCode 경로가 클라 쓰기로 세팅하므로 여기서 잠그지 않는다.
    function protectedFieldsNotChanged() {
      return !fieldChanged('tier') &&
             !fieldChanged('updatedAt') &&
             !fieldChanged('updatedBy') &&
             !fieldChanged('referredBy') &&
             !fieldChanged('totalReferrals');
    }

    // ==================== USERS 컬렉션 ====================
    // 사용자는 자신의 문서만 읽기 가능
    match /users/{userId} {
      allow read: if isOwner(userId);

      // 신규 사용자 문서 생성 — 본인 문서만. 추천 이력·티어 필드는 초기값이어야 한다(자가 세팅 방지).
      // create 시 resource 가 null 이라 protectedFieldsNotChanged() 의 diff(resource.data) 가
      // 평가 에러를 내 무조건 거부되므로(신규 가입 사망), create/update 를 분리한다.
      allow create: if isOwner(userId) &&
                    (!('referredBy' in request.resource.data) || request.resource.data.referredBy == null) &&
                    (!('totalReferrals' in request.resource.data) || request.resource.data.totalReferrals == 0) &&
                    !('tier' in request.resource.data) &&
                    !('updatedAt' in request.resource.data) &&
                    !('updatedBy' in request.resource.data);

      // 기존 문서 수정 — 구독 티어·추천 이력 등 보호 필드는 변경 불가(서버 Admin SDK 전용).
      allow update: if isOwner(userId) && protectedFieldsNotChanged();

      // 관리자는 모든 사용자 문서 읽기 가능
      allow read: if currentUserIsAdmin();

      // ==================== SUBSCRIPTIONS 서브컬렉션 ====================
      // 사용자는 자신의 구독 정보만 읽기 가능
      match /subscriptions/{subscriptionDoc} {
        allow read: if isOwner(userId);

        // 구독 정보는 클라이언트에서 절대 쓰기 불가
        // (서버 Admin SDK 또는 결제 처리 시스템에서만 업데이트)
        allow write: if false;

        // 관리자는 모든 사용자의 구독 정보 읽기 가능
        allow read: if currentUserIsAdmin();
      }
    }

    // ==================== REFERRALS 컬렉션 ====================
    // 추천 기록 - 추천인 또는 피추천인 본인만 읽기 가능
    match /referrals/{referralDoc} {
      allow read: if isAuthenticated() && (
        resource.data.referrerId == request.auth.uid ||
        resource.data.referredId == request.auth.uid
      );

      // 쓰기는 백엔드(Admin SDK)에서만 가능
      allow write: if false;
    }

    // ==================== REFERRAL_CODES 컬렉션 ====================
    // 추천 코드 - 클라이언트 read 금지(코드 열거/저엔트로피 코드 무단 수집 방지).
    // 추천코드 적용·검증·소비·티어부여는 전부 Cloud Function(redeemReferralCode)이
    // 단일 트랜잭션으로 Admin SDK를 통해 처리하므로 클라이언트 직접 read/write는 불필요.
    // 관리자 콘솔의 코드 목록 조회만 허용.
    match /referral_codes/{codeDoc} {
      allow read: if currentUserIsAdmin();

      // 쓰기는 백엔드(Admin SDK/Cloud Function)에서만 가능
      allow write: if false;
    }

    // ==================== PURCHASE_TOKENS 컬렉션 ====================
    // 결제 멱등성 잠금 — Cloud Function(verifyAndRecordPurchase)이 Admin SDK로만 쓴다.
    // 클라이언트 read/write 모두 금지.
    match /purchase_tokens/{tokenHash} {
      allow read, write: if false;
    }

    // ==================== VERIFIED_CAMERAS 컬렉션 ====================
    // 익명 연결 검증 집계 — 쓰기·공개 읽기 모두 Cloud Function(Admin SDK)이 대행한다.
    // reportCameraConnection(기록)·getVerifiedCameras(HTTP 공개 읽기)·deleteVerifiedCamera(admin 삭제)
    // 만 접근하며, 클라이언트 SDK 직접 read/write 는 금지.
    match /verified_cameras/{modelKey} {
      allow read, write: if false;
    }

    // ==================== 기본 규칙: 모든 다른 경로 차단 ====================
    // 위의 명시적 규칙에 매칭되지 않는 모든 접근은 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
